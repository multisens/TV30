<!DOCTYPE html>
<html>
    <head>
        <link rel="stylesheet" href="/css/all.css">
        <style>
            :root {
                --base-size: 1vw;
                --foreground-color: <%= foregroundColor %>;
                --background-color: <%= backgroundColor %>;
                --genre-color: <%= genreColor %>;
            }

            body {
                margin: 0;
                padding: 0;
                overflow: hidden;
                height: 100%;
                font-family: Verdana;
            }

            .main {
                position: relative;
                width: 100vw;
                height: 100vh;

                > * {
                    position: absolute;
                    display: block;
                    border: none;
                }
            }

            .pane {
                background-color: var(--background-color);
                color: var(--foreground-color);
            }

            #top-pane {
                left: 35%;
                top: 0;
                width: 65%;
                height: 12%;
            }

            #left-pane {
                left: 0;
                top: 0;
                width: 35%;
                height: 100%;
                display: grid;
                align-items: center;
                text-align: center;
                gap: 1vw;
                grid-template-columns: 100%;
                grid-template-rows: 1fr 4fr 1fr 1fr 5fr 1fr 1fr;
                overflow: hidden;
                
                .icon {
                    flex: 1;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    width: 100%;
                    height: 100%;
                    overflow: hidden;
                }

                svg {
                    max-width: 90%;
                    max-height: 90%;
                    width: auto;
                    height: auto;
                    display: block;
                }

                .name {
                    font-size: calc(1.5vw + 1vh);
                }

                .description {
                    font-size: calc(0.85vw + 0.5vh);
                }

                .btn {
                    width: 50%;
                    margin-left: 10%;
                    display: grid;
                    align-items: center;
                    grid-template-columns: 1fr 5fr;
                    grid-template-rows: 100%;
                    font-size: calc(0.85vw + 0.5vh);

                    div {
                        border: 2px solid var(--foreground-color);
                        width: 50%;
                        height: 50%;
                        padding: 25%;
                        text-align: center;
                    }
                }
            }

            #right-pane {
                left: 95%;
                top: 12%;
                width: 5%;
                height: 60%;
            }

            #bottom-pane {
                left: 35%;
                top: 72%;
                width: 65%;
                height: 28%;
                display: grid;
                align-items: center;
                gap: 1vw;
                grid-template-columns: 2fr 5fr 1fr;
                grid-template-rows: 80%;
                font-size: calc(1vw + 0.7vh);
                
                .pginfo {
                    display: grid;
                    align-items: center;
                    text-align: center;
                    gap: 1vw;
                    grid-template-columns: 100%;
                    grid-template-rows: 2fr 1fr;
                    border-right: 2px solid var(--foreground-color);
                    padding: 10px;

                    .pgname {
                        font-size: calc(1.5vw + 1vh);
                    }
                }

                .pgclass {
                    display: grid;
                    align-items: center;
                    text-align: center;
                    gap: 1vw;
                    grid-template-columns: 100%;
                    grid-template-rows: 1fr 2fr;
                    margin-right: 1vh;

                    .pggenre {
                        background-color: var(--genre-color);
                        border-radius: 1.5vh;
                        padding-top: 1vh;
                        padding-bottom: 1vh;
                    }

                    img {
                        width: 60%;
                        margin-left: auto;
                        margin-right: auto;
                    }
                }
            }

            #profile {
                left: 97%;
                top: 2%;
                width: 13%;
                height: 8%;
                transform: translateX(-100%);
                border-radius: 1vh;
                background-color: rgba(210, 210, 210, 0.03);
                color: var(--foreground-color);
                font-size: calc(0.75vw + 0.45vh);
                align-items: center;
                text-align: center;
                display: grid;
                gap: 1vw;
                grid-template-columns: 3fr 1fr;
                grid-template-rows: 100%;

                img {
                    height: 90%;
                    margin-right: 0.3vw;
                }
            }

            #mainvideo {
                top: 12%;
                left: 35%;
                width: 60%;
                height: 60%
            }

            .focused {
                outline: 2px solid var(--foreground-color);
            }
        </style>
        <script src="/js/jquery-3.7.1.min.js"></script>
        <script src="/js/navigation.js"></script>
    </head>
    <body>
        <div class="main">
            <div id="top-pane" class="pane"></div>
            <div id="right-pane" class="pane"></div>

            <div id="profile" movedown="mainvideo" select="profileManager">
                <%- profile %>
            </div>

            <div id="left-pane" class="pane">
                <div></div>
                <div class="icon">
                    <%- appIcon %>
                </div>
                <span class="name"><%= appName %></span>
                <span class="description"><%= appDescription %></span>
                <div></div>
                <div id="btnback" class="btn focused" moveup="mainvideo" select="appCatalog">
                    <div><i class="fa-solid fa-chevron-left"></i></div>
                    <span>Back to your <br/> Over-the-air TV Apps</span>
                </div>
            </div>

            <div id="bottom-pane" class="pane">
                <div class="pginfo">
                    <span class="pgname"><%= contentName %></span>
                    <span><%= validFrom %> - <%= validTo %></span>
                </div> 
                <span><%= contentDescription %></span>
                <div class="pgclass">
                    <span class="pggenre"><%= genreTerm %></span>
                    <img src="<%= contentAdvisoryRatings %>"/>
                </div>
            </div>

            <div id="mainvideo" moveup="profile" movedown="btnback" select="fullscreen"></div>
        </div>
    
        <script>
            document.addEventListener('keydown', (e) => {navigate(e.key)});

            function profileManager() {
                fetch('<%= basepath %>/profile');
            }

            function appCatalog() {
                fetch(`<%= basepath %>/appcat`);
            }

            function fullscreen() {
                fetch(`<%= basepath %>/fullscr`);
            }
        </script>
  </body>
</html>