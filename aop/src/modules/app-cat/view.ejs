<!DOCTYPE html>
<html>
    <head>
        <link rel="stylesheet" href="/css/all.css">
        <style>
            :root {
                --base-size: 1vw; /* Unidade base baseada na largura da viewport */
            }

            body {
                margin: 0;
                padding: 0;
                overflow: hidden;
                height: 100%;
                font-family: Verdana;
                background-color: rgb(40, 40, 40);
            }

            .main {
                position: relative;
                width: 100vw;
                height: 100vh;

                > * {
                    position: absolute;
                    display: block;
                    border: none;
                }
            }

            #logo {
                left: 10%;
                top: 2%;
                width: 10%;
            }

            #instruction {
                color: rgb(255,255,255);
                font-size: calc(0.75vw + 0.45vh);
                top: 12%;
                left: 5%;
                width: 45%;
                line-height: 1.4;
            }

            #disclaimer {
                color: rgb(183,183,183);
                font-size: calc(0.7vw + 0.4vh);
                text-align: center;
                top: 97%;
                left: 0;
                width: 100%;
                transform: translateY(-100%);
                line-height: 1.3;
            }

            #profile {
                left: 97%;
                top: 2%;
                width: 13%;
                height: 8%;
                transform: translateX(-100%);
                border-radius: 1vh;
                background-color: rgb(45, 45, 45);
                color: rgb(200,200,200);
                font-size: calc(0.75vw + 0.45vh);
                align-items: center;
                text-align: center;
                display: grid;
                gap: 1vw;
                grid-template-columns: 3fr 1fr;
                grid-template-rows: 100%;

                img {
                    height: 90%;
                    margin-right: 0.3vw;
                }
            }

            #search {
                background-color: rgb(50, 50, 50);
                left: 55%;
                top: 8%;
                width: 20%;
                height: 4%;
                border-radius: 1vh;
                align-items: center;
                display: grid;
                gap: 1vw;
                grid-template-columns: 1fr 9fr 1fr;
                grid-template-rows: 100%;
                color: rgb(110,110,110);
                font-size: calc(0.7vw + 0.4vh);

                .center {
                    text-align: center;
                }
            }

            #menu {
                background-color: rgb(30, 30, 30);
                left: 3%;
                top: 20%;
                width: 17%;
                height: 70%;
                border-radius: 1vh;
                align-items: center;
                display: grid;
                gap: 1vw;
                grid-template-columns: 100%;
                grid-template-rows: 1fr 1fr 1fr 1fr 1fr 2fr;

                > div {
                    color: rgb(200,200,200);
                    font-size: calc(0.85vw + 0.5vh);
                    margin-left: 5%;
                    margin-right: 5%;
                }

                .item {
                    display: grid;
                    gap: 1vw;
                    grid-template-columns: 1fr 4fr;
                    grid-template-rows: 100%;
                    align-items: center;

                    > i {
                        font-size: calc(1.4vw + 1vh);
                    }
                }
            }

            #catalog {
                left: 25%;
                top: 20%;
                width: 70%;
                height: 70%;
                display: grid;
                gap: 1vw;
                grid-template-columns: 1fr 1fr 1fr 1fr;
                grid-template-rows: 1fr 1fr 1fr 1fr;

                .card {
                    background-color: rgb(243, 243, 243);
                    border-radius: 1.5vh;
                    align-items: center;
                    text-align: center;
                    display: grid;
                    grid-template-columns: 100%;
                    grid-template-rows: 1fr 3fr;
                    overflow: hidden;

                    .logo {
                        flex: 1;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        width: 100%;
                        height: 100%;
                        overflow: hidden;
                    }
                    svg {
                        max-width: 80%;
                        max-height: 80%;
                        width: auto;
                        height: auto;
                        display: block;
                    }
                }

                .focused {
                    outline: 3px solid rgb(150, 150, 150);
                }
            }

            .focused {
                outline: 1.5px solid rgb(200, 200, 200);
            }
        </style>
        <script src="/js/jquery-3.7.1.min.js"></script>
        <script src="/js/navigation.js"></script>
    </head>
    <body>
        <div class="main">
            <img id="logo" src="/media/logodtv.png"/>
            <span id="instruction">The order of the applications below is used for zapping and guides. You can customize it by selecting any application (pressing the OK button for 3 sec) and moving it.</span>
            
            <div id="search" class="focused" moveleft="menumenu" moveright="profile" movedown="card0">
                <div class="center"><i class="fas fa-search"></i></div>
                <span>Search Over-the-air TV</span>
                <div class="center"><i class="fas fa-microphone"></i></div>
            </div>

            <div id="profile" movedown="card0" moveleft="search" select="profileManager">
                <%- profile %>
            </div>

            <div id="menu">
                <div id="menumenu" class="item" moveup="search" movedown="menuguide" moveright="card0">
                    <i class="fas fa-bars"></i><span>Menu</span>
                </div>
                <div id="menuguide" class="item" moveup="menumenu" movedown="menupvcy" moveright="card0">
                    <i class="far fa-calendar-days"></i><span>Over-the-air <br/> TV Guides</span>
                </div>
                <div id="menupvcy" class="item" moveup="menuguide" movedown="menustng" moveright="card0">
                    <i class="far fa-user"></i><span>Data Privacy <br/> settings</span>
                </div>
                <div id="menustng" class="item" moveup="menupvcy" movedown="menuupdte" moveright="card0">
                    <i class="fas fa-gear"></i><span>More Over-the-air <br/> TV settings</span>
                </div>
                <div id="menuupdte" class="item" moveup="menustng" movedown="menuexit" moveright="card0">
                    <i class="fas fa-rotate-left"></i><span>Update Over-the-air <br/> TV apps</span>
                </div>
                <div id="menuexit" class="item" moveup="menuupdte" moveright="card0">
                    <i class="fas fa-xmark"></i><span>Exit <br/> Over-the-air TV</span>
                </div>
            </div>

            <div id="catalog">
                <%- cards %>
            </div>

            <span id="disclaimer">In compliance with the General Data Protection Regulation (GDPR), broadcasters will request permission to use your profile data or collect other personal information.</span>
        </div>
    
        <script>
            document.addEventListener('keydown', (e) => {navigate(e.key)});
            
            function profileManager() {
                fetch('<%= basepath %>/profile');
            }

            function selectService(sid) {
                fetch(`<%= basepath %>/select?id=${sid}`);
            }
        </script>
  </body>
</html>