<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Perfil - AoP</title>
    <style>
        body {
            background-color: #121212;
            color: #ffffff;
            font-family: Arial, sans-serif;
            margin: 30px;
            padding: 0;
            font-size: 25px;
        }

        h1 {
            color: #ffffff;
            text-align: left;
            margin: 20px 0 20px 20px;
        }

        .container {
            padding: 20px;
            width: 85%;
            border-radius: 40px;
            display: inline-block;
            text-align: left;
            vertical-align: top;
            margin-bottom: 50px;
        }

        .content {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        input[type="text"], select {
            width: 100%;
            padding: 15px;
            margin: 10px 0;
            border: 2px solid #888888;
            border-radius: 8px;
            background-color: #2a2a2a;
            color: #ffffff;
            font-size: 18px;
        }

        .profile-options {
            display: flex;
            align-items: center;
            margin: 15px 0;
        }

        .profile-options input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-right: 15px;
        }

        .gender-language {
            display: flex;
            gap: 20px;
            margin: 20px 0;
        }

        .gender-language select {
            flex: 1;
        }

        .language-options {
            margin: 20px 0;
        }

        .language-options label {
            display: block;
            margin-bottom: 10px;
            font-weight: bold;
        }

        .language-options select {
            width: 100%;
            margin: 5px 0;
        }

        .signing-config {
            background-color: #2a2a2a;
            padding: 20px;
            border-radius: 12px;
            margin: 20px 0;
            border: 2px solid #4CAF50;
        }

        .signing-config h3 {
            color: #4CAF50;
            margin-top: 0;
        }

        .signing-options {
            display: flex;
            gap: 30px;
            align-items: center;
        }

        .signing-options > div {
            flex: 1;
        }

        #closedSigningWidth {
            width: 100%;
            margin: 10px 0;
        }

        #width-value {
            color: #4CAF50;
            font-weight: bold;
            margin-left: 10px;
        }

        .content-rating-section {
            background-color: #2a2a2a;
            padding: 20px;
            border-radius: 12px;
            margin: 20px 0;
            border: 2px solid #ff9800;
        }

        .content-rating-section h3 {
            color: #ff9800;
            margin-top: 0;
        }

        /* === MODAL DE SELEÇÃO DE AVATAR === */
        .avatar-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .avatar-modal-content {
            background-color: #121212;
            border-radius: 12px;
            padding: 30px;
            width: 80%;
            max-width: 800px;
            max-height: 80%;
            overflow-y: auto;
            border: 2px solid #4CAF50;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #333;
            padding-bottom: 15px;
        }

        .modal-header h2 {
            margin: 0;
            color: #4CAF50;
        }

        .close-btn {
            background: none;
            border: none;
            color: #ffffff;
            font-size: 30px;
            cursor: pointer;
            padding: 0;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            transition: background-color 0.3s ease;
        }

        .close-btn:hover {
            background-color: #333;
        }

        .avatar-categories {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            justify-content: center;
        }

        .category-btn {
            padding: 12px 25px;
            border: 2px solid #888888;
            border-radius: 8px;
            background-color: #2a2a2a;
            color: #ffffff;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .category-btn:hover {
            border-color: #4CAF50;
        }

        .category-btn.active {
            background-color: #4CAF50;
            border-color: #4CAF50;
            color: #121212;
            font-weight: bold;
        }

        .avatar-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 15px;
            margin: 25px 0;
            max-height: 400px;
            overflow-y: auto;
        }

        .avatar-option {
            border: 3px solid transparent;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            padding: 10px;
            text-align: center;
            background-color: #2a2a2a;
        }

        .avatar-option:hover {
            border-color: #888888;
            transform: scale(1.05);
        }

        .avatar-option.selected {
            border-color: #4CAF50;
            background-color: #1a4a1a;
            transform: scale(1.1);
        }

        .avatar-option img {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
            margin-bottom: 8px;
        }

        .avatar-option .avatar-name {
            font-size: 12px;
            color: #cccccc;
        }

        .modal-actions {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-top: 25px;
            padding-top: 15px;
            border-top: 2px solid #333;
        }

        .modal-actions .btn {
            min-width: 120px;
        }

        .ratings {
            display: flex;
            gap: 10px;
            margin: 20px 0;
            justify-content: center;
        }

        .ratings img {
            width: 80px;
            height: auto;
            cursor: pointer;
            border: 3px solid transparent;
            border-radius: 8px;
            transition: border-color 0.3s ease;
        }

        .ratings img.selected {
            border-color: #4CAF50;
        }

        .accessibility-options {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin: 30px 0;
        }

        .accessibility-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            cursor: pointer;
            padding: 15px;
            border: 2px solid transparent;
            border-radius: 12px;
            transition: border-color 0.3s ease;
            min-width: 120px;
        }

        .accessibility-item.selected {
            border-color: #4CAF50;
            background-color: #1a4a1a;
        }

        .accessibility-item img {
            width: 60px;
            height: 60px;
            margin-bottom: 10px;
        }

        .avatar-section {
            text-align: center;
            padding: 20px;
            margin-left: 30px;
        }

        .avatar-button {
            background: none;
            border: 3px solid #888888;
            border-radius: 50%;
            padding: 10px;
            cursor: pointer;
            transition: border-color 0.3s ease;
        }

        .avatar-button:hover {
            border-color: #4CAF50;
        }

        .avatar-button img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
        }

        .terms-actions {
            margin-top: 30px;
        }

        .terms {
            margin: 20px 0;
            display: flex;
            align-items: flex-start;
            gap: 15px;
        }

        .terms input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-top: 5px;
        }

        .actions {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-top: 30px;
        }

        .btn {
            padding: 15px 30px;
            border: 2px solid #888888;
            border-radius: 8px;
            background-color: #2a2a2a;
            color: #ffffff;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn:hover {
            background-color: #4CAF50;
            border-color: #4CAF50;
        }

        .btn.advance {
            background-color: #4CAF50;
            border-color: #4CAF50;
        }

        .btn.advance:hover {
            background-color: #45a049;
        }

        a {
            color: #4CAF50;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
    <script src="/jquery-3.7.1.min.js"></script>
    <script src="/navigation.js"></script>
</head>
<body>
    <h1>Criando seu Perfil Smart TV</h1>
    
    <div class="content">
        <div class="container">
            <form id="profile-form">
                <input type="text" id="name" name="name" placeholder="Nome do perfil (obrigatório)" required>
                
                <!-- Perfil de grupo -->
                <div class="profile-options">
                    <input type="checkbox" id="group-profile" name="group-profile">
                    <label for="group-profile">Este é um Perfil de Grupo (ex.: família, hóspedes...)</label>
                </div>
                
                <div class="gender-language">
                    <select id="gender" name="gender">
                        <option value="M">Masculino</option>
                        <option value="F">Feminino</option>
                        <option value="NB">Não Binário</option>
                    </select>
                </div>

                <!-- Configurações de Idioma separadas conforme norma -->
                <div class="language-options">
                    <label>Configurações de Idioma:</label>
                    <select id="audioLanguage" name="audioLanguage">
                        <option value="pt-br">Áudio: Português</option>
                        <option value="en">Áudio: Inglês</option>
                    </select>
                    <select id="closeCaptioningLanguage" name="closeCaptioningLanguage">
                        <option value="pt-br">Legendas: Português</option>
                        <option value="en">Legendas: Inglês</option>
                    </select>
                    <select id="userInterfaceLanguage" name="userInterfaceLanguage">
                        <option value="pt-br">Interface: Português</option>
                        <option value="en">Interface: Inglês</option>
                    </select>
                </div>
                
                <div class="Group-classification">
                    <div class="profile-options">
                        <input type="checkbox" id="child-profile" name="child-profile">
                        <label for="child-profile">Este é um Perfil de Criança</label>
                    </div>
                    <div class="ratings">
                        <img id="livre" src="/media/Livre.png" alt="Livre" onclick="selectRating('livre')">
                        <img id="10anos" src="/media/10anos.png" alt="10 anos" onclick="selectRating('10anos')">
                        <img id="12anos" src="/media/12anos.png" alt="12 anos" onclick="selectRating('12anos')">
                        <img id="14anos" src="/media/14anos.png" alt="14 anos" onclick="selectRating('14anos')">
                        <img id="16anos" src="/media/16anos.png" alt="16 anos" onclick="selectRating('16anos')">
                        <img id="18anos" src="/media/18anos.png" alt="18 anos" onclick="selectRating('18anos')">
                    </div>
                </div>
                
                <!-- Botões de Acessibilidade -->
                <div class="accessibility-options">
                    <div class="accessibility-item" onclick="toggleAccessibility('audio-description')">
                        <img id="audio-description" src="/media/audio-description.png" alt="Audiodescrição">
                        <label>Audiodescrição</label>
                    </div>
                    <div class="accessibility-item" onclick="toggleAccessibility('sign-language')">
                        <img id="sign-language" src="/media/sign-language.png" alt="Acessível em Libras">
                        <label>Acessível em Libras</label>
                    </div>
                    <div class="accessibility-item" onclick="toggleAccessibility('closed-caption')">
                        <img id="closed-caption" src="/media/closed-caption.png" alt="Legendas ocultas">
                        <label>Legendas ocultas</label>
                    </div>
                    <div class="accessibility-item" onclick="toggleAccessibility('dialogue-enhancement')">
                        <img id="dialogue-enhancement" src="/media/dialogue-enhancement.png" alt="Aprimoramento de Diálogo">
                        <label>Aprim. de Diálogo</label>
                    </div>
                    <div class="accessibility-item" onclick="toggleAccessibility('voice-guidance')">
                        <img id="voice-guidance" src="/media/voice-guidance.png" alt="Guia por Voz">
                        <label>Guia por Voz</label>
                    </div>
                </div>

                <!-- Configurações da Janela de Libras (norma ABNT NBR 25608) -->
                <div id="signing-config" class="signing-config" style="display: none;">
                    <h3>Configurações da Janela de Libras</h3>
                    <div class="signing-options">
                        <div>
                            <label for="closedSigningSide">Posição da Janela:</label>
                            <select id="closedSigningSide" name="closedSigningSide">
                                <option value="right">Direita</option>
                                <option value="left">Esquerda</option>
                            </select>
                        </div>
                        <div>
                            <label for="closedSigningWidth">Largura da Janela (%):</label>
                            <input type="range" min="14" max="28" value="20" id="closedSigningWidth" name="closedSigningWidth">
                            <span id="width-value">20%</span>
                        </div>
                    </div>
                </div>

                <!-- Classificação Etária (Condicional - apenas se controle parental ativo) -->
                <div id="content-rating-section" class="content-rating-section" style="display: none;">
                    <h3>Classificação Máxima Permitida</h3>
                    <select id="maxContentRating" name="maxContentRating">
                        <option value="L">Livre</option>
                        <option value="10">10 anos</option>
                        <option value="12">12 anos</option>
                        <option value="14">14 anos</option>
                        <option value="16">16 anos</option>
                        <option value="18">18 anos</option>
                    </select>
                </div>
            </form>
        </div>
        
        <!-- Seção de Avatar -->
        <div class="avatar-section">
            <button type="button" class="avatar-button" onclick="openAvatarSelection()">
                <img id="selected-avatar" src="/media/profile.png" alt="Escolher Avatar">
            </button>
            <label>Escolha seu Avatar:</label>
        </div>
    </div>

    <!-- Modal de Seleção de Avatar -->
    <div id="avatar-modal" class="avatar-modal" style="display: none;">
        <div class="avatar-modal-content">
            <div class="modal-header">
                <h2>Escolha seu Avatar</h2>
                <button class="close-btn" onclick="closeAvatarModal()">&times;</button>
            </div>
            
            <!-- Categorias -->
            <div class="avatar-categories">
                <button class="category-btn active" data-category="default" onclick="loadAvatarCategory('default')">
                    Padrões
                </button>
                <button class="category-btn" data-category="animals" onclick="loadAvatarCategory('animals')">
                    Animais
                </button>  
                <button class="category-btn" data-category="places" onclick="loadAvatarCategory('places')">
                    Lugares
                </button>
            </div>
            
            <!-- Grid de avatares -->
            <div class="avatar-grid" id="avatar-grid">
                <!-- Avatares carregados dinamicamente -->
            </div>
            
            <div class="modal-actions">
                <button class="btn" onclick="closeAvatarModal()">Cancelar</button>
                <button class="btn advance" onclick="confirmAvatar()">Confirmar</button>
            </div>
        </div>
    </div>
    
    <div class="terms-actions">
        <!-- Seção de Termos -->
        <div class="terms">
            <input type="checkbox" id="terms" name="terms" required>
            <label for="terms">
                Concordo com a coleta e processamento de meus dados para uma melhor experiência, em conformidade com a Lei Geral de Proteção de Dados Pessoais (LGPD).
                <a href="#">Saiba mais.</a>
            </label>
        </div>
        
        <!-- Botões -->
        <div class="actions">
            <button type="button" class="btn create" onclick="createAnother()">Criar Outro</button>
            <button type="button" class="btn advance" onclick="saveProfile()">Avançar</button>
        </div>
    </div>

    <script>
        // Funções do Profile Creation adaptadas para o AoP
        
        function selectRating(ratingId) {
            const ratings = document.querySelectorAll('.ratings img');
            ratings.forEach(rating => {
                rating.classList.remove('selected');
            });
            const selectedRating = document.getElementById(ratingId);
            selectedRating.classList.add('selected');
        }

        function toggleAccessibility(accessibilityId) {
            const element = document.getElementById(accessibilityId).parentElement;
            element.classList.toggle('selected');
            
            // Mostrar configurações da janela de libras se libras for ativado
            if (accessibilityId === 'sign-language') {
                const signingConfig = document.getElementById('signing-config');
                const isSelected = element.classList.contains('selected');
                signingConfig.style.display = isSelected ? 'block' : 'none';
            }
        }

        // === SISTEMA DE SELEÇÃO DE AVATARES ===
        
        let selectedAvatar = '/media/profile.png'; // Avatar padrão
        let tempSelectedAvatar = null; // Avatar temporariamente selecionado no modal

        // Configuração dos avatares disponíveis
        const AVATARS = {
            default: [
                { id: '0.png', name: 'Avatar Padrão 1', path: '/0.png' },
                { id: '1.png', name: 'Avatar Padrão 2', path: '/1.png' },
                { id: '2.png', name: 'Avatar Padrão 3', path: '/2.png' },
                { id: 'profile.png', name: 'Avatar Genérico', path: '/media/profile.png' }
            ],
            animals: [
                { id: 'animal1.jpg', name: 'Animal 1', path: '/media/avatars/animal1.jpg' },
                { id: 'animal2.jpg', name: 'Animal 2', path: '/media/avatars/animal2.jpg' },
                { id: 'animal3.jpg', name: 'Animal 3', path: '/media/avatars/animal3.jpg' },
                { id: 'animal4.jpg', name: 'Animal 4', path: '/media/avatars/animal4.jpg' },
                { id: 'animal5.jpg', name: 'Animal 5', path: '/media/avatars/animal5.jpg' }
            ],
            places: [
                { id: 'place1.jpg', name: 'Lugar 1', path: '/media/avatars/place1.jpg' },
                { id: 'place2.jpg', name: 'Lugar 2', path: '/media/avatars/place2.jpg' },
                { id: 'place3.jpg', name: 'Lugar 3', path: '/media/avatars/place3.jpg' },
                { id: 'place4.jpg', name: 'Lugar 4', path: '/media/avatars/place4.jpg' },
                { id: 'place5.jpg', name: 'Lugar 5', path: '/media/avatars/place5.jpg' }
            ]
        };

        function openAvatarSelection() {
            document.getElementById('avatar-modal').style.display = 'flex';
            loadAvatarCategory('default');
            tempSelectedAvatar = selectedAvatar; // Backup do avatar atual
        }

        function closeAvatarModal() {
            document.getElementById('avatar-modal').style.display = 'none';
            tempSelectedAvatar = null;
        }

        function loadAvatarCategory(category) {
            // Atualizar botões de categoria
            document.querySelectorAll('.category-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.dataset.category === category) {
                    btn.classList.add('active');
                }
            });

            // Carregar avatares da categoria
            const avatarGrid = document.getElementById('avatar-grid');
            avatarGrid.innerHTML = '';

            const categoryAvatars = AVATARS[category] || [];
            
            categoryAvatars.forEach(avatar => {
                const avatarDiv = document.createElement('div');
                avatarDiv.className = 'avatar-option';
                avatarDiv.onclick = () => selectAvatarFromModal(avatar.path, avatarDiv);
                
                // Marcar como selecionado se for o avatar atual
                if (avatar.path === selectedAvatar || avatar.path === tempSelectedAvatar) {
                    avatarDiv.classList.add('selected');
                }
                
                avatarDiv.innerHTML = `
                    <img src="${avatar.path}" alt="${avatar.name}" onerror="this.src='/media/profile.png'">
                    <div class="avatar-name">${avatar.name}</div>
                `;
                
                avatarGrid.appendChild(avatarDiv);
            });
        }

        function selectAvatarFromModal(avatarPath, element) {
            // Remover seleção anterior
            document.querySelectorAll('.avatar-option.selected').forEach(opt => {
                opt.classList.remove('selected');
            });
            
            // Selecionar novo avatar
            element.classList.add('selected');
            tempSelectedAvatar = avatarPath;
            
            // Preview instantâneo
            document.getElementById('selected-avatar').src = avatarPath;
        }

        function confirmAvatar() {
            if (tempSelectedAvatar) {
                selectedAvatar = tempSelectedAvatar;
            }
            closeAvatarModal();
        }

        function saveProfile() {
            const name = document.getElementById('name').value;
            const groupProfile = document.getElementById('group-profile').checked;
            const childProfile = document.getElementById('child-profile').checked;
            const gender = document.getElementById('gender').value;

            // Idiomas separados conforme norma
            const audioLanguage = document.getElementById('audioLanguage').value;
            const closeCaptioningLanguage = document.getElementById('closeCaptioningLanguage').value;
            const userInterfaceLanguage = document.getElementById('userInterfaceLanguage').value;

            const selectedRating = document.querySelector('.ratings img.selected');
            const ageRating = selectedRating ? selectedRating.id : null;

            // Configurações de acessibilidade
            const captions = document.getElementById('closed-caption').parentElement.classList.contains('selected');
            const signLanguageWindow = document.getElementById('sign-language').parentElement.classList.contains('selected');
            const audioDescription = document.getElementById('audio-description').parentElement.classList.contains('selected');
            const dialogueEnhancement = document.getElementById('dialogue-enhancement').parentElement.classList.contains('selected');
            const voiceGuidance = document.getElementById('voice-guidance').parentElement.classList.contains('selected');

            // Configurações da janela de libras (norma ABNT NBR 25608)
            const closedSigningSide = document.getElementById('closedSigningSide').value;
            const closedSigningWidth = parseInt(document.getElementById('closedSigningWidth').value);

            // Classificação máxima (obrigatória se controle parental ativo)
            const maxContentRating = childProfile ? document.getElementById('maxContentRating').value : null;

            // Validações conforme norma
            if (!name || !document.getElementById('terms').checked) {
                alert('Por favor, preencha todos os campos obrigatórios e aceite os termos.');
                return;
            }

            if (name.length > 20) {
                alert('O nome deve ter no máximo 20 caracteres.');
                return;
            }

            if (childProfile && !maxContentRating) {
                alert('Por favor, selecione a classificação máxima permitida para o perfil de criança.');
                return;
            }

            // Objeto conforme norma ABNT NBR 25608
            const newProfile = {
                // Campos básicos
                name,
                isGroup: groupProfile,
                parentalControl: childProfile,
                gender,
                
                // Avatar selecionado
                avatar: selectedAvatar,
                
                // Idiomas separados
                audioLanguage,
                closeCaptioningLanguage, 
                userInterfaceLanguage,
                language: audioLanguage, // Para compatibilidade
                
                // Configurações de acessibilidade
                captions,
                closedCaptioning: captions, // Nome da norma
                signLanguageWindow,
                closedSigning: signLanguageWindow, // Nome da norma
                audioDescription,
                dialogueEnhancement,
                dialogEnhancement: dialogueEnhancement, // Nome da norma
                voiceGuidance,
                
                // Configurações da janela de libras
                closedSigningSide,
                closedSigningWidth,
                
                // Classificação etária
                ageRating,
                maxContentRating
            };

            // Enviar para o endpoint do AoP
            fetch('/profile/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(newProfile)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Perfil criado com sucesso!');
                    // Voltar para a tela de perfis
                    window.location.href = '/profile';
                } else {
                    alert('Erro ao criar perfil: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao criar perfil.');
            });
        }

        function createAnother() {
            // Limpar formulário para criar outro perfil
            document.getElementById('profile-form').reset();
            document.querySelectorAll('.ratings img.selected').forEach(img => img.classList.remove('selected'));
            document.querySelectorAll('.accessibility-item.selected').forEach(item => item.classList.remove('selected'));
        }

        // Event listeners para funcionalidades da norma
        document.addEventListener('DOMContentLoaded', function() {
            // Mostrar/ocultar seção de classificação baseado no controle parental
            document.getElementById('child-profile').addEventListener('change', function() {
                const ratingSection = document.getElementById('content-rating-section');
                ratingSection.style.display = this.checked ? 'block' : 'none';
            });

            // Atualizar display da largura da janela de libras
            document.getElementById('closedSigningWidth').addEventListener('input', function() {
                document.getElementById('width-value').textContent = this.value + '%';
            });

            // Sincronizar idiomas por padrão
            document.getElementById('audioLanguage').addEventListener('change', function() {
                const selectedLang = this.value;
                document.getElementById('closeCaptioningLanguage').value = selectedLang;
                document.getElementById('userInterfaceLanguage').value = selectedLang;
            });
        });

        // Navegação com teclado para o modal de avatar
        document.addEventListener('keydown', function(e) {
            const modal = document.getElementById('avatar-modal');
            const isModalOpen = modal.style.display === 'flex';
            
            if (isModalOpen) {
                if (e.key === 'Escape') {
                    closeAvatarModal();
                } else if (e.key === 'Enter') {
                    confirmAvatar();
                } else if (e.key === 'ArrowLeft' || e.key === 'ArrowRight' || e.key === 'ArrowUp' || e.key === 'ArrowDown') {
                    // Navegação entre avatares com setas
                    const avatars = document.querySelectorAll('.avatar-option');
                    const selected = document.querySelector('.avatar-option.selected');
                    
                    if (avatars.length > 0) {
                        let currentIndex = Array.from(avatars).indexOf(selected);
                        let newIndex = currentIndex;
                        
                        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
                            newIndex = (currentIndex + 1) % avatars.length;
                        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
                            newIndex = (currentIndex - 1 + avatars.length) % avatars.length;
                        }
                        
                        avatars[newIndex].click();
                        avatars[newIndex].scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
                e.preventDefault(); // Prevenir ação padrão no modal
            } else if (e.key === 'Escape') {
                window.location.href = '/profile';
            }
        });
    </script>
</body>
</html>
