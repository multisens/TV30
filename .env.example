# TV30 — defaults pra deploy Linux + Docker.
#
# Uso na maquina nova:
#   cp .env.example .env
#   docker compose up -d

# Profiles ativos. Sem isto, AoP/CCWS/bcast/sysctl-init/mosquitto nao sobem
# (todos tem profile "linux" ou "mqtt" no compose).
COMPOSE_PROFILES=mqtt,linux

# Imagens publicadas no Docker Hub. IMAGE_TAG=latest puxa o build mais recente da main.
DOCKERHUB_NS=labmultisens
IMAGE_TAG=latest

# Porta WebSocket do Mosquitto exposta no host. Default 9001 funciona em
# Linux puro. Em Windows+WSL2 com 9001/9002 ocupadas no host (Hyper-V),
# definir 9003.
MQTT_WS_PORT=9001

# Porta do bcast exposta no host. Default 8081. Sobrescreva se a porta
# estiver ocupada na maquina (ex: BCAST_PORT=8082).
BCAST_PORT=8081

